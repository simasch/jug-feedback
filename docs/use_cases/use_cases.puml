@startuml use_cases
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor "Anonymous\nUser" as anon
actor "Form\nOwner" as owner
actor "Template\nOwner" as towner
actor "Shared\nUser" as shared

rectangle "Feedback" {
    usecase "UC-01\nLogin" as UC01
    usecase "UC-02\nCreate Form" as UC02
    usecase "UC-03\nEdit Form" as UC03
    usecase "UC-04\nPublish Form" as UC04
    usecase "UC-05\nSubmit Feedback" as UC05
    usecase "UC-06\nView Results" as UC06
    usecase "UC-07\nShare Form" as UC07
    usecase "UC-08\nGenerate QR Code" as UC08
    usecase "UC-09\nClose Form" as UC09
    usecase "UC-10\nReopen Form" as UC10
    usecase "UC-11\nDelete Form" as UC11
    usecase "UC-12\nSave Form as Template" as UC12
    usecase "UC-13\nCreate Form from Template" as UC13
    usecase "UC-14\nManage Templates" as UC14
    usecase "UC-16\nUnpublish Form" as UC16
}

anon --> UC01
anon --> UC05

owner --> UC02
owner --> UC03
owner --> UC04
owner --> UC06
owner --> UC07
owner --> UC08
owner --> UC09
owner --> UC10
owner --> UC11
owner --> UC12
owner --> UC16
owner --> UC13

towner --> UC14

shared --> UC06
shared --> UC08

owner --|> anon : extends
shared --|> anon : extends
towner --|> anon : extends
@enduml
